# Base URL for the Go backend API.
# Local dev: leave unset to use the default http://localhost:8080/api/v1
# Production (Vercel): set in Project Settings → Environment Variables.
#   - "/api/v1" when the API is proxied through Vercel (see vercel.json)
#   - "https://api.todo-manager.app/api/v1" for a direct cross-origin backend
VITE_API_BASE_URL=http://localhost:8080/api/v1
